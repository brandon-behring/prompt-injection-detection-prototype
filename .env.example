# Required env vars for Phase 1-5 execution.
# Lock: see decisions/ADR-035-secrets-management-three-store-split.md
#
# USAGE:
#   1. Copy this file to .env (gitignored): cp .env.example .env
#   2. Fill in real token values (replace placeholders below)
#   3. DO NOT commit .env — .gitignore covers it; gitleaks pre-commit hook catches
#
# Token sources:
#   HF_TOKEN          — https://huggingface.co/settings/tokens (write-scope for ADR-032 publication)
#   RUNPOD_API_KEY    — https://www.runpod.io/console/user/settings
#   OPENAI_API_KEY    — https://platform.openai.com/api-keys
#   ANTHROPIC_API_KEY — https://console.anthropic.com/settings/keys
#
# Consumer libraries (all use env-var auto-discovery by default):
#   huggingface_hub    -> HF_TOKEN     (ADR-016 datasets + ADR-032 model publish)
#   runpod-deploy CLI  -> RUNPOD_API_KEY (ADR-020 GPU dispatch)
#   openai SDK         -> OPENAI_API_KEY (ADR-018 R-LLM-OpenAI scorer)
#   anthropic SDK      -> ANTHROPIC_API_KEY (ADR-018 R-LLM-Anthropic scorer)

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_API_KEY=YOUR_RUNPOD_API_KEY_HERE
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxx
