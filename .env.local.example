# .env.local — local-only secrets template (gitignored per .gitignore .env.* pattern).
#
# Copy this file to .env.local and paste your real keys. Scripts that need
# secrets read via os.environ.get(KEY); ensure your shell loads .env.local
# (e.g. via `set -a; source .env.local; set +a` or use a tool like direnv).
#
# Per ADR-035 three-store split — .env.local is the local store; RunPod
# pod-secrets + GH Actions repo Secrets are the cloud + CI stores.

# Required for HF Hub gated datasets (hackaprompt; potentially lmsys-chat-1m).
HF_TOKEN=

# Required for scripts/llm_prelabel_dedup_holdout.py (per ADR-042).
# Snapshot pinned by ADR-018: gpt-4o-2024-08-06.
OPENAI_API_KEY=

# Required for Phase 3+ LLM-as-rater (per ADR-018).
ANTHROPIC_API_KEY=

# Required for Phase 2+ RunPod GPU runs (per ADR-020).
RUNPOD_API_KEY=
