__pycache__/
*.py[oc]
.venv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
*.egg-info/
build/
dist/
.DS_Store
evals/predictions/
evals/checkpoints/
# Phase 1 data outputs — large + private; manifest (data/source_manifest.yaml) is committed.
data/raw/
data/processed/
data/dedup_holdout.jsonl
data/contamination_templates.parquet
# HF default cache may live under repo if HF_HOME points here — never commit.
.hf_cache/
# Secrets — never commit (repo is public)
.env
.env.*
# Exemption: .env.example is the committed placeholder template per ADR-035
!.env.example
*.key
*.pem
*.p12
*.cert
secrets/
.secrets/
# SUBMISSION two-version split: TEMPLATE is committed; filled SUBMISSION.md is local-only
SUBMISSION.md
# Transcripts: private by default. The README.md inside transcripts/ stays tracked as the convention doc.
transcripts/*.md
!transcripts/README.md
# Auto-saved transcripts (SessionEnd hook output) — private like the rest
transcripts/auto/
