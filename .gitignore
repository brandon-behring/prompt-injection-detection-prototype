__pycache__/
*.py[oc]
.venv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
*.egg-info/
build/
dist/
.DS_Store
evals/predictions/
evals/predictions_val/
evals/checkpoints/
# Phase 1 data outputs — large + private; manifest is committed at configs/data/source_manifest.yaml per ADR-044 Q2.
# data/ is reserved for non-committed HF cache + processed parquets + dedup-holdout JSONL per ADR-026 layout.
data/raw/
data/processed/
data/dedup_holdout.jsonl
data/contamination_templates.parquet
# HF default cache may live under repo if HF_HOME points here — never commit.
.hf_cache/
# Secrets — never commit (repo is public)
.env
.env.*
# Exemption: .env.example + .env.local.example are committed placeholder templates per ADR-035 + ADR-042
!.env.example
!.env.local.example
*.key
*.pem
*.p12
*.cert
secrets/
.secrets/
# SUBMISSION two-version split: TEMPLATE is committed; filled SUBMISSION.md is local-only
SUBMISSION.md
# Transcripts: private by default. The README.md inside transcripts/ stays tracked as the convention doc.
transcripts/*.md
!transcripts/README.md
# Auto-saved transcripts (SessionEnd hook output) — private like the rest
transcripts/auto/
# Raw-session-archive zip (companion to transcripts/*.md; same private-by-default discipline)
transcripts/*.zip

# Smoke-time fixture outputs (per ADR-027 + ADR-044 Q7 + ADR-045 Commit 6) —
# committed inputs live at tests/fixtures/processed/; predictions + checkpoints +
# metrics are runtime artifacts of the smoke pipeline pass.
tests/fixtures/predictions/
tests/fixtures/checkpoints/
tests/fixtures/metrics/
tests/fixtures/plots/

# Phase 3 LLM-judge response cache (per A-007 + A-014 + ADR-045 Q4) — cache
# files carry vendor responses + are not part of the methodology contract.
evals/audit/llm_judge_cache/

# Phase 6+7 background-job logs (val inference + bootstrap + cv-clt-ci) — operational
# noise; some are >100 MB (marginal_bootstrap_*.log). Manifest .md files in this
# dir stay tracked as the durable artifact summaries.
artifacts/local/*.log

# RunPod pod manifests for non-canonical fires (operational noise from v1.1.2
# DeBERTa execution + smoke/validation passes). Canonical-fire pod manifests
# get committed explicitly via `seed:` commits using `git add -f` (precedent:
# `seed: lora + full-FT canonical runs chained on shared pod (X9-validated)`).
# The headline methodology result is captured in `evals/metrics/per_cell*.parquet`
# + `evals/cost_ledger.csv`; pod manifests are redundant operational state by default.
artifacts/runpod/2026*/

.claude/scheduled_tasks.lock

/.quarto/

# Quarto rendered site (built locally; CI publishes to gh-pages branch)
/_site/

# Local-only scratch drafts + review notes (not part of submission)
/draft.md
/draft_review.md
.scratch/
